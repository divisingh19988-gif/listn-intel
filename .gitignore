# Secrets — never commit
.env
.streamlit/secrets.toml

# Raw data files — regenerated by scrapers/monitors
*.json
*.pdf

# But keep sample data in repo so deployed dashboard renders on day one
!sample_data/*.json

# Keep canonical data files (refreshed weekly by GitHub Actions)
!data/*.json

# Keep weekly Excel reports
!reports/*.xlsx

# Python cache
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/

# macOS
.DS_Store

# Virtual environments
venv/
.venv/
env/

# Spartan AI config (contains API keys)
.spartan/ai.env

# Unrelated nested projects sitting in this working directory
caveman/
claude-seo/
