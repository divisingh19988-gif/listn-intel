# Copy this file to .env and fill in real values. .env is gitignored.

# Meta Ad Library API
META_TOKEN=

# Anthropic Claude API (used by analyze_ads.py and dashboard hygiene review)
ANTHROPIC_API_KEY=

# Legacy SMTP email (kept for compatibility — Resend is the active path)
EMAIL_SENDER=
EMAIL_PASSWORD=

# DataForSEO (SEO competitor monitoring)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Apify (alternate scraper backend)
Apify_API_Key=

# Supabase project — used by Streamlit pages and the Next.js dashboard
SUPABASE_URL=
Supabase_anon_key=

# Supabase service-role key (D-3): required by lib/supabase_writer.py so the
# weekly cron can upload briefs/reports to Storage and write metadata rows
# without per-bucket RLS policies. NEVER expose this key in client code.
SUPABASE_SERVICE_ROLE_KEY=

# Resend (weekly email reports)
Resend_API_Key=
RESEND_FROM_EMAIL=
REPORT_EMAIL=
